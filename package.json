{
  "name": "shen-shi-man-hua",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && node --import tsx build/generate-manifest.ts && cross-env NODE_OPTIONS=\"--import tsx\" rspack build && node --import tsx build/generate-brotli.ts",
    "dev": "pnpm dev:serve",
    "dev:serve": "tsx dev-server.ts"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.1",
    "@rspack/core": "^2.0.1",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "ky": "^2.0.2"
  }
}